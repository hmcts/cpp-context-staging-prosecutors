{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/prosecution-received.json",
  "type": "object",
  "properties": {
    "submissionId" : {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "submissionStatus" : {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/definitions.json#/definitions/submissionStatus"
    },
    "prosecutionSubmissionDetails": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/prosecution-submission-details.json"
    },
    "defendants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/defendant.json"
      }
    }
  },
  "required": [
    "submissionId",
    "submissionStatus",
    "prosecutionSubmissionDetails",
    "defendants"
  ],
  "additionalProperties" : false
}