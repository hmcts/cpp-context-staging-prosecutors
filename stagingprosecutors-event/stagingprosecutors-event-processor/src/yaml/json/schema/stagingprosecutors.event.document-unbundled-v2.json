{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/document-unbundled-v2.json",
  "type": "object",
  "properties": {
    "caseId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutingAuthority": {
      "type": "string",
      "description": "Identifies the Prosecuting Organisation responsible for initiating the case. Valid CJS OU Code.",
      "maxLength": 7
    },
    "prosecutorDefendantId": {
      "type": "string",
      "maxLength": 36
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fileStoreId": {
            "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
          },
          "documentType": {
            "type": "string"
          },
          "fileType": {
            "type": "string"
          },
          "isUnbundledDocument": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "fileStoreId",
          "documentType",
          "fileType"
        ],
        "additionalProperties": false
      }
    },
    "receivedDateTime": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date-time"
    }
  },
  "required": [
    "caseId",
    "prosecutorDefendantId",
    "materials",
    "receivedDateTime"
  ],
  "additionalProperties": false
}