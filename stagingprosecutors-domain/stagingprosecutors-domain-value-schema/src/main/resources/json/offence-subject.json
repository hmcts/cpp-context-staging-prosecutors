{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/offence-subject.json",
  "type": "object",
  "properties": {
    "cjsOffenceCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8
    },
    "offenceDate": {
      "type": "string",
      "format" : "date",
      "pattern": "^((([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13578]|1[02])\\-(0[1-9]|[12]\\d|3[01]))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13456789]|1[012])\\-(0[1-9]|[12]\\d|30))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-02\\-(0[1-9]|1\\d|2[0-8]))|(((1[6-9]|[2-9]\\d)(0[48]|[2468][048]|[13579][26])|((16|[2468][048]|[3579][26])00))\\-02\\-29))$"
    },
    "offenceWording": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8100
    }
  },
  "required": [
    "cjsOffenceCode",
    "offenceDate",
    "offenceWording"
  ],
  "additionalProperties": false
}