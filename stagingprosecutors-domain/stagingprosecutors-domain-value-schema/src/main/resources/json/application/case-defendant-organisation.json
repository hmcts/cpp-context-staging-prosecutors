{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/application/json/schemas/case-defendant-organisation.json",
  "type": "object",
  "description": "Case defendant organisation",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the organisation"
    },
    "asn": {
      "type": "string",
      "description": "A unique reference to a defendant within a prosecution. Provided by the police force and requested from the police"
    },
    "prosecutorDefendantId": {
      "type": "string",
      "description": "A unique reference to a defendant "
    }
  },
  "additionalProperties": false
}