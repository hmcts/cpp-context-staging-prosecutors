{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/prosecutor-person-defendant-details.json",
  "type": "object",
  "description": "The defendant person details for material relating to a defendant required to be matched with a defendant id provided by the prosecuting authority",
  "properties": {
    "title": {
      "description": "Title by which a defendant is addressed",
      "type": "string",
      "maxLength": 35,
      "pattern": "^(Mr|Mrs|Ms|Dr|Rev|Sir|Lady|Lord|Dame)$"
    },
    "forename": {
      "description": "The first given name of a defendant",
      "type": "string",
      "pattern": "^(?!.*  ).+",
      "minLength": 1,
      "maxLength": 35
    },
    "forename2": {
      "description": "The second given name of a defendant",
      "type": "string",
      "pattern": "^(?!.*  ).+",
      "maxLength": 35
    },
    "forename3": {
      "description": "The third given name of a defendant",
      "type": "string",
      "pattern": "^(?!.*  ).+",
      "maxLength": 35
    },
    "surname": {
      "description": "Surname or Family name",
      "type": "string",
      "pattern": "^(?!.*  ).+",
      "minLength": 1,
      "maxLength": 35
    },
    "dateOfBirth": {
      "description": "The date when the defendant was born",
      "type": "string",
      "pattern": "^((([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13578]|1[02])\\-(0[1-9]|[12]\\d|3[01]))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13456789]|1[012])\\-(0[1-9]|[12]\\d|30))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-02\\-(0[1-9]|1\\d|2[0-8]))|(((1[6-9]|[2-9]\\d)(0[48]|[2468][048]|[13579][26])|((16|[2468][048]|[3579][26])00))\\-02\\-29))$"

    },
    "parentGuardianForYouthDefendants": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/defendant-parent-guardian.json"
    },
    "localAuthorityDetailsForYouthDefendants": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/local-authority-details-for-youth-defendants.json"
    },
    "prosecutorDefendantId": {
      "description": "A unique reference to a defendant within a prosecution. Provided by the prosecuting authority e.g. DWP",
      "type": "string",
      "minLength": 1,
      "maxLength": 36
    }
  },
  "required": [
    "forename",
    "surname",
    "prosecutorDefendantId",
    "dateOfBirth"
  ],
  "additionalProperties": false
}