{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/sjp-defendant.json",
  "type": "object",
  "description": "Defendant Details of the case",
  "properties": {
    "asn": {
      "type": "string",
      "description": "Arrest / Summons number",
      "maxLength": 20
    },
    "defendantPerson": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/sjp-person.json",
      "description": "Defendant is a person"
    },
    "organisation": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/sjp-organisation.json",
      "description": "Defendant is a company"
    },
    "documentationLanguage": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/language.json"
    },
    "hearingLanguage": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/language.json"
    },
    "languageRequirement": {
      "type": "string",
      "description": "Notes about the defendant’s language needs, e.g. interpreter details",
      "maxLength": 150
    },
    "specificRequirements": {
      "type": "string",
      "description": "Notes about any help that the defendant may need when attending court – e.g. wheelchair access.",
      "maxLength": 150
    },
    "prosecutorCosts": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/definitions.json#/definitions/money",
      "description": "Prosecution costs claimed by prosecutor."
    },
    "numPreviousConvictions": {
      "type": "integer",
      "description": "Number of previous conviction cited by prosecutor."
    },
    "offences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/sjp-offence.json"
      }
    },
    "prosecutorDefendantId": {
      "description": "DefendantId provided by prosecutor.",
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]*$",
      "maxLength": 36
    }
  },
  "oneOf": [
    {
      "required": [
        "defendantPerson"
      ]
    },
    {
      "required": [
        "organisation"
      ]
    }
  ],
  "required": [
    "documentationLanguage",
    "hearingLanguage",
    "offences",
    "prosecutorDefendantId",
    "prosecutorCosts"
  ],
  "additionalProperties": true
}