    $outcome.setSuccess(true);
end

rule "Query - Rule for getting submission for sjp v2 endpoint and v3 response type"
  when
    $outcome: Outcome();
    $action: Action(name == "hmcts.cjs.sjp.submission.v3");
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($action, RuleConstants.getQuerySubmissionGroups()));
  then
    $outcome.setSuccess(true);
end

rule "Query - Rule for getting submission for non sjp v2 endpoint and v3 response type"
  when
    $outcome: Outcome();
    $action: Action(name == "hmcts.cjs.submission.v3");
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($action, RuleConstants.getQuerySubmissionGroups()));
  then
    $outcome.setSuccess(true);
end