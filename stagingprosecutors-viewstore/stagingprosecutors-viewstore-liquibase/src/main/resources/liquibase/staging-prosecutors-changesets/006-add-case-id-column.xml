<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.3.xsd">

    <!--
     Postgres specific changeset for production.
     Adds a column 'case_urn' of type TEXT to the table 'submission'
    -->
    <changeSet
        id="staging.prosecutors-006"
        author="Staging-Prosecutors"
        logicalFilePath="006-add-case-urn-column.xml">
        <addColumn tableName="submission">
            <column name="case_urn" type="text"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>