<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.3.xsd">

    <!--
     Postgres specific changeset for production.
     Adds a column 'errors' of type JsonB to the table 'submission'
    -->
    <changeSet id="staging.prosecutors-002b" author="Staging-Prosecutors"
               logicalFilePath="002b-add-job-data-column-postgres.xml"
               dbms="postgresql">
        <addColumn tableName="submission">
            <column name="errors" type="JSONB"/>
            <column name="warnings" type="JSONB"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>