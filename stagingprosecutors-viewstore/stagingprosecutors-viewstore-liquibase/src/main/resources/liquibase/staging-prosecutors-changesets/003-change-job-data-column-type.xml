<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.3.xsd">

    <!--
     Postgres specific changeset for production.
     Adds a column 'errors' of type JsonB to the table 'submission'
    -->
    <changeSet id="staging.prosecutors-003" author="Staging-Prosecutors"
               logicalFilePath="003-change-job-data-column-type.xml"
               dbms="postgresql">
        <modifyDataType tableName="submission" columnName="errors" newDataType="text" />
        <modifyDataType tableName="submission" columnName="warnings" newDataType="text" />
    </changeSet>
</databaseChangeLog>