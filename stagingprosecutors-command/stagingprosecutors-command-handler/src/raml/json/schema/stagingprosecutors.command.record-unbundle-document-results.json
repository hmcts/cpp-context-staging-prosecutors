{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://uk.gov.moj.cpp/staging/prosecutors/json/schemas/record-unbundle-document-results.json",
  "type": "object",
  "properties": {
    "caseId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutorDefendantId": {
      "type": "string",
      "maxLength": 36
    },
    "prosecutingAuthority": {
      "type": "string",
      "description": "Identifies the Prosecuting Organisation responsible for initiating the case.",
      "maxLength": 36
    },
    "errorMessage": {
      "type": "string"
    },
    "materials": {
      "type": "array",
      "items": {
        "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/material.json"
      }
    },
    "receivedDateTime": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/date-time"
    }
  },
  "required": [
    "caseId",
    "prosecutorDefendantId"
  ],
  "additionalProperties": false
}
