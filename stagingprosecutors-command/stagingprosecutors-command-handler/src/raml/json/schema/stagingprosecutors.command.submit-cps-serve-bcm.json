{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/command/api/submit-cps-serve-bcm.json",
  "type": "object",
  "properties": {
    "prosecutionCaseSubject": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/cps-prosecution-case-subject.json",
      "description": "Identifies the case to which the form is associated to"
    },
    "defendantOffencesSubject": {
      "description": "Identifies the defendant and offences to which the form is associated to",
      "type": "array",
      "items": {
        "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/defendant-offences-subjects.json"
      }
    },
    "tag": {
      "type": "string"
    },
    "evidencePrePTPH": {
      "type": "string"
    },
    "evidencePostPTPH": {
      "type": "string"
    },
    "otherInformation": {
      "type": "string"
    },
    "submissionId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "submissionStatus": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/json/schemas/definitions.json#/definitions/submissionStatus"
    }
  },
  "required": [
    "prosecutionCaseSubject",
    "defendantOffencesSubject",
    "submissionId"
  ],
  "anyOf": [
    {
      "required": [
        "evidencePrePTPH"
      ]
    },
    {
      "required": [
        "evidencePostPTPH"
      ]
    },
    {
      "required": [
        "otherInformation"
      ]
    }
  ],
  "additionalProperties": true
}