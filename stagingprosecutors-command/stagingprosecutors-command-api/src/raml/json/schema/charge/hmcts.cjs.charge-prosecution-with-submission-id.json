{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://cpp.moj.gov.uk/staging/prosecutors/command/api/submit-charge-prosecution-with-submission-id.json",
  "type": "object",
  "properties": {
    "submissionId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutionSubmissionDetails": {
      "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/command/api/charge-prosecution-submission-details.json"
    },
    "defendants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://cpp.moj.gov.uk/staging/prosecutors/command/api/charge-defendant.json"
      }
    }
  },
  "required": [
    "submissionId",
    "prosecutionSubmissionDetails",
    "defendant"
  ],
  "additionalProperties": false
}
