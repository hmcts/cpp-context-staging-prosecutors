{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://uk.gov.moj.cpp/staging/prosecutors/json/schemas/submit-material-with-oucode.json",
  "type": "object",
  "properties": {
    "material": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "ptiUrn": {
      "type": "string",
      "maxLength": 36
    },
    "materialType": {
      "type": "string"
    },
    "defendantId": {
      "type": "string",
      "maxLength": 36
    },
    "srcDocumentReference": {
      "type": "string"
    }
  },
  "required": [
    "material",
    "ptiUrn",
    "materialType"
  ],
  "additionalProperties": false
}
